{
    "cli": {
        "version": ">= 3.0.0",
        "appVersionSource": "remote"
    },
    "build": {
        "simulator": {
            "ios": {
                "simulator": true
            },
            "env": {
                "EXPO_PUBLIC_API_URL": "https://lionfish-app-tkr7y.ondigitalocean.app/api",
                "EXPO_PUBLIC_SKIP_GEOFENCE": "true"
            }
        },
        "preview": {
            "android": {
                "buildType": "apk"
            },
            "env": {
                "EXPO_PUBLIC_API_URL": "https://lionfish-app-tkr7y.ondigitalocean.app/api",
                "EXPO_PUBLIC_USE_ADS": "true"
            }
        },
        "production": {
            "android": {
                "buildType": "app-bundle",
                "credentialsSource": "local"
            },
            "env": {
                "EXPO_PUBLIC_API_URL": "https://lionfish-app-tkr7y.ondigitalocean.app/api",
                "EXPO_PUBLIC_USE_ADS": "true"
            }
        }
    }
}
