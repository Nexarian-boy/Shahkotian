generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(uuid())
  name             String
  phone            String?           @unique
  email            String?           @unique
  whatsapp         String?
  password         String?
  photoUrl         String?
  role             Role              @default(USER)
  firebaseUid      String?           @unique
  latitude         Float?
  longitude        Float?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  isBlocked        Boolean           @default(false)
  lastSeenAt       DateTime?
  fcmToken         String?
  appointments     Appointment[]
  blockedByUsers   Block[]           @relation("Blocked")
  blockedUsers     Block[]           @relation("Blocker")
  bloodDonors      BloodDonor[]
  chatMessages     ChatMessage[]
  dmChatsAsUser1   DMChat[]          @relation("DMUser1")
  dmChatsAsUser2   DMChat[]          @relation("DMUser2")
  dmMessages       DMMessage[]       @relation("DMSender")
  jobs             Job[]
  jobApplications  JobApplication[]
  listings         Listing[]
  newsArticles     News[]
  notifications    Notification[]
  reportsSubmitted Report[]          @relation("ReportSubmitter")
  reportsReceived  Report[]          @relation("ReportTarget")
  sentInterests    RishtaInterest[]  @relation("SentInterests")
  rishtaProfile    RishtaProfile?
  shortlists       RishtaShortlist[] @relation("UserShortlists")
  shops            Shop[]
  traderProfile    Trader?

  @@index([latitude, longitude])
}

model Listing {
  id          String          @id @default(uuid())
  userId      String
  title       String
  description String
  price       Float
  category    ListingCategory
  images      String[]
  whatsapp    String
  isSold      Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  views       Int             @default(0)
  likedBy     String[]        @default([])
  videos      String[]
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([createdAt(sort: Desc)])
  @@index([userId])
  @@index([isSold, category, createdAt(sort: Desc)])
}

model Tournament {
  id            String    @id @default(uuid())
  sport         SportType
  name          String
  description   String
  image         String?
  venue         String
  startDate     DateTime
  endDate       DateTime?
  createdById   String?
  teams         String[]  @default([])
  prize         String?
  entryFee      Int?
  contactNumber String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  matches       Match[]

  @@index([sport])
  @@index([endDate])
}

model Match {
  id           String     @id @default(uuid())
  tournamentId String
  team1        String
  team2        String
  date         DateTime   @default(now())
  time         String     @default("")
  venue        String     @default("")
  result       String?
  round        String?
  score        String?
  createdAt    DateTime   @default(now())
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([tournamentId])
}

model GovtOffice {
  id          String   @id @default(uuid())
  name        String
  address     String
  latitude    Float?
  longitude   Float?
  helplines   String[]
  timings     String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Shop {
  id          String   @id @default(uuid())
  name        String
  address     String
  contact     String
  categories  String[]
  description String?
  ownerId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owner       User?    @relation(fields: [ownerId], references: [id], onUpdate: NoAction)

  @@index([categories])
  @@index([ownerId])
}

model RishtaProfile {
  id              String            @id @default(uuid())
  userId          String            @unique
  cnicFront       String?
  cnicBack        String?
  age             Int
  gender          String
  education       String
  occupation      String
  familyDetails   String?
  preferences     String?
  images          String[]
  signatureAgreed Boolean           @default(false)
  agreementText   String?
  status          RishtaStatus      @default(PENDING)
  adminNote       String?
  approvedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  interests       RishtaInterest[]  @relation("ReceivedInterests")
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  shortlistedBy   RishtaShortlist[]

  @@index([status])
}

model RishtaInterest {
  id         String        @id @default(uuid())
  fromUserId String
  profileId  String
  status     String        @default("PENDING")
  createdAt  DateTime      @default(now())
  fromUser   User          @relation("SentInterests", fields: [fromUserId], references: [id], onDelete: Cascade)
  profile    RishtaProfile @relation("ReceivedInterests", fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, profileId])
  @@index([profileId])
  @@index([fromUserId])
}

model RishtaShortlist {
  id        String        @id @default(uuid())
  userId    String
  profileId String
  createdAt DateTime      @default(now())
  profile   RishtaProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  user      User          @relation("UserShortlists", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, profileId])
  @@index([userId])
}

model NewsReporter {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  news      News[]
}

model News {
  id         String        @id @default(uuid())
  reporterId String?
  title      String
  content    String
  images     String[]
  category   NewsCategory
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  views      Int           @default(0)
  likedBy    String[]      @default([])
  userId     String?
  videos     String[]
  reporter   NewsReporter? @relation(fields: [reporterId], references: [id])
  user       User?         @relation(fields: [userId], references: [id])

  @@index([createdAt(sort: Desc)])
  @@index([category])
  @@index([userId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model ChatMessage {
  id            String        @id @default(uuid())
  userId        String
  text          String?
  images        String[]
  videos        String[]
  voiceUrl      String?
  voiceDuration Int?
  replyToId     String?
  createdAt     DateTime      @default(now())
  replyTo       ChatMessage?  @relation("ReplyTo", fields: [replyToId], references: [id])
  replies       ChatMessage[] @relation("ReplyTo")
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt(sort: Desc)])
  @@index([userId])
}

model BloodDonor {
  id          String     @id @default(uuid())
  userId      String
  name        String
  phone       String
  whatsapp    String?
  bloodGroup  BloodGroup
  address     String?
  isAvailable Boolean    @default(true)
  isEmergency Boolean    @default(false)
  lastDonated DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bloodGroup])
  @@index([isAvailable])
  @@index([isEmergency])
  @@index([userId])
}

model DMChat {
  id        String      @id @default(uuid())
  user1Id   String
  user2Id   String
  source    String      @default("GENERAL")
  isBlocked Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user1     User        @relation("DMUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2     User        @relation("DMUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages  DMMessage[]

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@index([updatedAt(sort: Desc)])
}

model DMMessage {
  id        String   @id @default(uuid())
  chatId    String
  senderId  String
  text      String?
  images    String[]
  createdAt DateTime @default(now())
  chat      DMChat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender    User     @relation("DMSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt(sort: Desc)])
  @@index([senderId])
}

model Report {
  id             String   @id @default(uuid())
  reporterUserId String
  targetUserId   String
  targetType     String
  targetId       String
  reason         String
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  reporter       User     @relation("ReportSubmitter", fields: [reporterUserId], references: [id], onDelete: Cascade)
  target         User     @relation("ReportTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([reporterUserId])
  @@index([targetUserId])
  @@index([status])
}

model Block {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model EmailOtp {
  id        String   @id @default(uuid())
  email     String
  otp       String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

model Job {
  id           String           @id @default(uuid())
  userId       String
  title        String
  company      String
  description  String
  category     JobCategory
  type         JobType          @default(FULL_TIME)
  salary       String?
  location     String           @default("Shahkot")
  phone        String
  whatsapp     String?
  requirements String?
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications JobApplication[]

  @@index([category])
  @@index([type])
  @@index([createdAt(sort: Desc)])
  @@index([userId])
  @@index([isActive, createdAt(sort: Desc)])
}

model JobApplication {
  id        String   @id @default(uuid())
  jobId     String
  userId    String
  message   String?
  phone     String
  createdAt DateTime @default(now())
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId])
  @@index([jobId])
  @@index([userId])
}

model Doctor {
  id               String          @id @default(uuid())
  name             String
  specialty        DoctorSpecialty
  clinicName       String?
  address          String
  phone            String
  whatsapp         String?
  timings          String?
  fee              Int?
  education        String?
  experience       String?
  isVerified       Boolean         @default(false)
  latitude         Float?
  longitude        Float?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  avgConsultTime   Int             @default(15)
  currentToken     Int             @default(0)
  email            String?         @unique
  endTime          String?
  onlineBooking    Boolean         @default(false)
  password         String?
  paymentAccount   String?
  paymentMethod    String?
  startTime        String?
  totalTokensToday Int             @default(0)
  isAvailableNow   Boolean         @default(false)
  weekdays         String?
  schedule         Json?
  appointments     Appointment[]

  @@index([specialty])
  @@index([name])
  @@index([email])
}

model Appointment {
  id              String            @id @default(uuid())
  doctorId        String
  userId          String
  status          AppointmentStatus @default(PENDING)
  tokenNumber     Int?
  appointmentDate DateTime
  estimatedTime   String?
  fee             Int?
  paymentMethod   String?
  paymentAccount  String?
  paymentProof    String?
  paymentVerified Boolean           @default(false)
  notes           String?
  cancelReason    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  doctor          Doctor            @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([doctorId, appointmentDate])
  @@index([userId])
  @@index([status])
}

model Restaurant {
  id          String   @id @default(uuid())
  name        String
  address     String
  phone       String?
  whatsapp    String?
  description String?
  image       String?
  email       String   @unique
  password    String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deals       Deal[]

  @@index([name])
  @@index([isActive])
}

model Deal {
  id            String     @id @default(uuid())
  restaurantId  String
  title         String
  description   String?
  price         String?
  originalPrice String?
  image         String?
  images        String[]   @default([])
  videos        String[]   @default([])
  isActive      Boolean    @default(true)
  expiresAt     DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  views         Int        @default(0)
  likedBy       String[]   @default([])
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([isActive, createdAt(sort: Desc)])
}

model ClothBrand {
  id          String      @id @default(uuid())
  name        String
  address     String
  phone       String?
  whatsapp    String?
  description String?
  image       String?
  email       String      @unique
  password    String
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deals       BrandDeal[]

  @@index([name])
  @@index([isActive])
}

model BrandDeal {
  id            String     @id @default(uuid())
  brandId       String
  title         String
  description   String?
  price         String?
  originalPrice String?
  images        String[]
  videos        String[]
  isActive      Boolean    @default(true)
  expiresAt     DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  views         Int        @default(0)
  likedBy       String[]   @default([])
  brand         ClothBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId])
  @@index([isActive, createdAt(sort: Desc)])
}

model Bazar {
  id                String             @id @default(uuid())
  name              String             @unique
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  bazarChatMessages BazarChatMessage[]
  traders           Trader[]

  @@index([isActive])
}

model Trader {
  id           String             @id @default(uuid())
  userId       String             @unique
  fullName     String
  shopName     String
  phone        String
  photoUrl     String?
  bazarId      String
  status       TraderStatus       @default(PENDING)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  chatMessages BazarChatMessage[]
  bazar        Bazar              @relation(fields: [bazarId], references: [id], onDelete: Cascade)
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bazarId, status])
  @@index([status])
}

model BazarChatMessage {
  id            String             @id @default(uuid())
  traderId      String
  bazarId       String?
  text          String?
  images        String[]
  videos        String[]
  voiceUrl      String?
  voiceDuration Int?
  pollQuestion  String?
  pollOptions   String[]
  pollVotes     String[]
  createdAt     DateTime           @default(now())
  replyToId     String?
  bazar         Bazar?             @relation(fields: [bazarId], references: [id])
  replyTo       BazarChatMessage?  @relation("BazarReplyTo", fields: [replyToId], references: [id])
  replies       BazarChatMessage[] @relation("BazarReplyTo")
  trader        Trader             @relation(fields: [traderId], references: [id], onDelete: Cascade)

  @@index([createdAt(sort: Desc)])
  @@index([traderId])
}

model President {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([email])
}

enum Role {
  USER
  VERIFIED_USER
  NEWS_REPORTER
  ADMIN
}

enum RishtaStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ListingCategory {
  ELECTRONICS
  VEHICLES
  PROPERTY
  FURNITURE
  CLOTHING
  SPORTS
  BOOKS
  HOME_APPLIANCES
  MOBILE_PHONES
  OTHER
}

enum SportType {
  CRICKET
  FOOTBALL
  KABADDI
  VOLLEYBALL
  HOCKEY
  BADMINTON
  TABLE_TENNIS
  OTHER
}

enum NewsCategory {
  LOCAL
  SPORTS
  EDUCATION
  POLITICS
  BUSINESS
  HEALTH
  ENTERTAINMENT
  OTHER
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  DAILY_WAGE
}

enum JobCategory {
  TEACHING
  MEDICAL
  IT
  DRIVING
  LABOUR
  SHOP_WORK
  OFFICE
  COOKING
  TAILORING
  AGRICULTURE
  OTHER
}

enum DoctorSpecialty {
  GENERAL_PHYSICIAN
  PEDIATRICIAN
  GYNECOLOGIST
  CARDIOLOGIST
  DERMATOLOGIST
  ENT
  ORTHOPEDIC
  DENTIST
  OPHTHALMOLOGIST
  NEUROLOGIST
  PSYCHIATRIST
  UROLOGIST
  HOMEOPATHIC
  HAKEEM
  OTHER
}

enum AppointmentStatus {
  PENDING
  APPROVED
  PAYMENT_PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum TraderStatus {
  PENDING
  APPROVED
  REJECTED
}
